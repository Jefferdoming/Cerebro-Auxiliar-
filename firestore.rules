rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation helpers
    function isValidRecord(data) {
      return data.keys().hasAll(['userId', 'type', 'amount', 'description', 'status', 'dueDate', 'priority', 'createdAt'])
        && data.userId == request.auth.uid
        && data.type in ['income', 'bill', 'debt']
        && data.amount is number
        && data.description is string && data.description.size() <= 1000
        && (data.createdAt == request.time || data.createdAt is timestamp)
        && (!('category' in data) || data.category is string);
    }

    function isValidLoan(data) {
      return data.keys().hasAll(['userId', 'description', 'totalAmount', 'monthlyAmount', 'totalInstallments', 'paidInstallments', 'createdAt'])
        && data.userId == request.auth.uid
        && data.description is string && data.description.size() <= 500
        && data.totalAmount is number
        && data.monthlyAmount is number
        && data.totalInstallments is number
        && data.paidInstallments is number
        && (data.createdAt == request.time || data.createdAt is timestamp)
        && (!('category' in data) || data.category is string);
    }

    function isValidInvestment(data) {
      return data.keys().hasAll(['userId', 'description', 'amount', 'type', 'createdAt'])
        && data.userId == request.auth.uid
        && data.description is string && data.description.size() <= 200
        && data.amount is number
        && data.type in ['capitalization', 'piggybank', 'other']
        && (data.createdAt == request.time || data.createdAt is timestamp)
        && (!('category' in data) || data.category is string);
    }

    function isValidDelivery(data) {
      return data.keys().hasAll(['userId', 'date', 'appUsed', 'deliveriesCount', 'grossIncome', 'fuelCost', 'maintenanceCost', 'tips', 'totalKm', 'status', 'createdAt'])
        && data.userId == request.auth.uid
        && data.date is string && data.date.size() == 10
        && data.appUsed is string
        && data.deliveriesCount is number
        && data.grossIncome is number
        && data.fuelCost is number
        && data.maintenanceCost is number
        && data.tips is number
        && data.totalKm is number
        && data.status in ['active', 'completed']
        && (data.createdAt == request.time || data.createdAt is timestamp);
    }

    function isValidCommitment(data) {
      return data.keys().hasAll(['userId', 'microHabit', 'date', 'isCompleted', 'createdAt'])
        && data.userId == request.auth.uid
        && data.microHabit is string && data.microHabit.size() <= 500
        && data.date is string && data.date.size() == 10
        && data.isCompleted is bool
        && (data.createdAt == request.time || data.createdAt is timestamp);
    }

    // Collections
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId
        && request.resource.data.userId == resource.data.userId
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'role', 'onboardingComplete', 'createdAt', 'energyLevel', 'crisisMode', 'lastActiveDate', 'secondaryRole', 'preferences'])
        );
    }

    match /tasks/{taskId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /habits/{habitId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /commitments/{commitmentId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidCommitment(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isCompleted', 'microHabit'])
        );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /financial_records/{recordId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidRecord(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['amount', 'description', 'dueDate', 'status', 'priority', 'category'])
        );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /loans/{loanId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidLoan(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['paidInstallments', 'interestRate', 'description', 'totalAmount', 'monthlyAmount', 'totalInstallments', 'category'])
        );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /investments/{investmentId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidInvestment(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['amount', 'description', 'type', 'totalInstallments', 'paidInstallments', 'monthlyContribution', 'category'])
        );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /deliveries/{deliveryId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidDelivery(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deliveriesCount', 'totalKm', 'grossIncome', 'fuelCost', 'maintenanceCost', 'tips', 'appUsed', 'status'])
        );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /finances/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
    }

    match /wellness_metrics/{metricId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /daily_insights/{insightId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /moto_maintenance/{userId} {
      allow get, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /maintenance_logs/{logId} {
      allow list, get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /app_content/{contentId} {
      allow read: if true;
    }

    match /onboarding_responses/{responseId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /events/{eventId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /journal_entries/{entryId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /routines/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
    }

    match /routine_history/{historyId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /remembrances/{remembranceId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
